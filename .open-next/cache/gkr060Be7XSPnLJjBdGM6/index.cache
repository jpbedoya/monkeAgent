{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"4294967294","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/34efe2816c50ed13.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-9edee2920554d0a5.js\"/><script src=\"/_next/static/chunks/4bd1b696-92f787ce67d7893e.js\" async=\"\"></script><script src=\"/_next/static/chunks/684-8976800b730f6c24.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-cecb8c9ce022c858.js\" async=\"\"></script><script src=\"/_next/static/chunks/874-450ef3267553834d.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-aafb15e323ace4e9.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><title>MonkeAgent — Your AI Agent, Deployed in Minutes</title><meta name=\"description\" content=\"No terminal. No server setup. No DevOps. Your own AI running 24/7 on dedicated infrastructure — built by MonkeDAO on OpenClaw.\"/><link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\" sizes=\"16x16\"/><link href=\"https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&amp;family=JetBrains+Mono:wght@300;400;500&amp;display=swap\" rel=\"stylesheet\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"font-sans antialiased\"><main class=\"min-h-screen\"><nav class=\"fixed top-0 left-0 right-0 z-50 bg-[rgba(10,14,11,0.92)] backdrop-blur-xl\" style=\"border-bottom:0.5px solid rgba(74,143,93,0.18)\"><div class=\"mx-auto flex items-center justify-between px-8 py-4\" style=\"max-width:1200px\"><a class=\"flex items-center gap-2.5 font-bold text-lg tracking-tight\" style=\"color:#E8F0E9\" href=\"/\"><span class=\"flex h-8 w-8 items-center justify-center rounded-lg border text-lg\" style=\"background:var(--g-dark);border:1px solid var(--g);font-size:16px\">🐵</span>MonkeAgent</a><div class=\"hidden items-center gap-8 sm:flex\"><a href=\"#features\" class=\"text-xs font-medium uppercase tracking-widest transition-colors hover:text-[var(--g-light)]\" style=\"color:rgba(134,201,148,0.55);letter-spacing:0.04em\">Features</a><a href=\"#pricing\" class=\"text-xs font-medium uppercase tracking-widest transition-colors hover:text-[var(--g-light)]\" style=\"color:rgba(134,201,148,0.55);letter-spacing:0.04em\">Pricing</a><a class=\"text-xs font-medium uppercase tracking-widest transition-colors hover:text-[var(--g-light)]\" style=\"color:rgba(134,201,148,0.55);letter-spacing:0.04em\" href=\"/privacy\">Privacy</a></div><a class=\"rounded-md px-5 py-2 text-sm font-semibold transition hover:opacity-90\" style=\"background:var(--g);color:#0A0E0B;letter-spacing:0.02em\" href=\"/signup\">Get Early Access</a></div></nav><section class=\"w-full\"><div class=\"mx-auto grid items-center px-8\" style=\"max-width:1200px;grid-template-columns:1fr 1fr;gap:5rem;padding-top:7rem;padding-bottom:5rem\"><div class=\"flex flex-col gap-6\"><div class=\"inline-flex items-center gap-1.5 rounded-full px-4 py-1.5 text-xs font-medium uppercase\" style=\"background:rgba(24,70,35,0.5);border:0.5px solid var(--g);color:var(--g-light);letter-spacing:0.1em;font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace;align-self:flex-start\"><span class=\"h-1.5 w-1.5 rounded-full\" style=\"background:var(--g-light);animation:pulse 2s infinite\"></span>agent.monke.is</div><h1 class=\"font-extrabold leading-tight tracking-tight\" style=\"font-size:clamp(2.6rem, 5vw, 4rem);letter-spacing:-0.035em;line-height:1.05;color:#F0F7F1\">Your agent.<br/>Already<!-- --> <em style=\"font-style:normal;color:var(--g-light)\">at work.</em></h1><p class=\"text-base leading-relaxed\" style=\"color:rgba(134,201,148,0.65);max-width:480px;line-height:1.75\">No dashboard to open. No tab to switch to. Your operator runs 24/7 and shows up where you already are.</p><div class=\"flex flex-wrap gap-2\"><div class=\"flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs\" style=\"background:rgba(24,70,35,0.3);border:0.5px solid rgba(74,143,93,0.15);color:rgba(134,201,148,0.5);font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\"><span class=\"h-1 w-1 rounded-full\" style=\"background:var(--g-light)\"></span>Telegram</div><div class=\"flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs\" style=\"background:rgba(24,70,35,0.3);border:0.5px solid rgba(74,143,93,0.15);color:rgba(134,201,148,0.5);font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\"><span class=\"h-1 w-1 rounded-full\" style=\"background:var(--g-light)\"></span>Discord</div><div class=\"flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs\" style=\"background:rgba(24,70,35,0.3);border:0.5px solid rgba(74,143,93,0.15);color:rgba(134,201,148,0.5);font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\"><span class=\"h-1 w-1 rounded-full\" style=\"background:var(--g-light)\"></span>Slack</div><div class=\"flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs\" style=\"background:rgba(24,70,35,0.3);border:0.5px solid rgba(74,143,93,0.15);color:rgba(134,201,148,0.5);font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\"><span class=\"h-1 w-1 rounded-full\" style=\"background:var(--g-light)\"></span>More</div></div><div class=\"flex items-center gap-4\"><a class=\"rounded-lg px-7 py-3.5 text-sm font-bold transition hover:translate-y-[-1px]\" style=\"background:var(--g);color:#0A0E0B;letter-spacing:0.01em\" href=\"/signup\">Get Early Access</a><a href=\"#features\" class=\"rounded-lg border px-6 py-3.5 text-sm font-medium transition\" style=\"border:0.5px solid rgba(134,201,148,0.35);color:rgba(134,201,148,0.65)\">See how it works</a></div></div><div class=\"flex justify-center\"><div style=\"width:260px;background:#0F1510;border:1.5px solid rgba(74,143,93,0.3);border-radius:36px;overflow:hidden\"><div style=\"height:28px;background:#0A0E0B;display:flex;align-items:center;justify-content:center\"><div style=\"width:60px;height:4px;background:#1E2620;border-radius:4px\"></div></div><div style=\"background:#17211A;padding:10px 12px;display:flex;align-items:center;gap:8px;border-bottom:0.5px solid rgba(74,143,93,0.15)\"><div style=\"width:32px;height:32px;border-radius:50%;background:var(--g-dark);border:1px solid var(--g);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0\">🐵</div><div style=\"flex:1\"><div style=\"font-size:12px;font-weight:700;color:#E8F2EA;letter-spacing:-0.01em\">My Operator</div><div style=\"font-size:9px;color:var(--g-light);font-family:var(--font-jetbrains), monospace\">online</div></div><div style=\"width:5px;height:5px;background:var(--g-light);border-radius:50%;animation:pulse 2s infinite\"></div></div><div style=\"padding:10px 10px 12px;display:flex;flex-direction:column;gap:8px;background:#0F1510;min-height:340px\"><div style=\"text-align:center;font-size:9px;color:rgba(134,201,148,0.3);font-family:var(--font-jetbrains), monospace;margin:4px 0\">Today, 8:00 AM</div><div style=\"display:flex;flex-direction:column;max-width:88%;align-self:flex-start\"><div style=\"background:#1E2E21;border:0.5px solid rgba(74,143,93,0.2);border-radius:14px 14px 14px 4px;padding:8px 11px;font-size:11px;line-height:1.55;color:#C8E8CC\">Good morning. Here&#x27;s what&#x27;s on your plate today.</div><div style=\"background:#17211A;border:0.5px solid rgba(74,143,93,0.25);border-radius:10px;overflow:hidden;margin-top:2px\"><div style=\"background:#1A2C1D;padding:5px 9px;font-size:9px;font-weight:700;color:var(--g-light);font-family:var(--font-jetbrains), monospace;letter-spacing:0.05em;display:flex;align-items:center;gap:5px\"><div style=\"width:5px;height:5px;background:var(--g-light);border-radius:50%\"></div>Morning brief — Apr 10</div><div style=\"padding:7px 9px;display:flex;flex-direction:column;gap:4px\"><div style=\"font-size:10px;color:rgba(200,232,204,0.8);display:flex;gap:6px;align-items:flex-start;line-height:1.4\"><span style=\"color:var(--y);flex-shrink:0\">★</span>4 unread emails flagged</div><div style=\"font-size:10px;color:rgba(200,232,204,0.8);display:flex;gap:6px;align-items:flex-start;line-height:1.4\"><span style=\"color:var(--y);flex-shrink:0\">↑</span>2pm meeting has new agenda</div><div style=\"font-size:10px;color:rgba(200,232,204,0.8);display:flex;gap:6px;align-items:flex-start;line-height:1.4\"><span style=\"color:var(--y);flex-shrink:0\">!</span>1 overdue task from yesterday</div><div style=\"font-size:10px;color:rgba(200,232,204,0.8);display:flex;gap:6px;align-items:flex-start;line-height:1.4\"><span style=\"color:var(--y);flex-shrink:0\">◎</span>Rest of the day is clear</div></div></div><div style=\"font-size:8px;color:rgba(134,201,148,0.3);font-family:var(--font-jetbrains), monospace;margin-top:3px;padding:0 3px\">8:00 AM</div></div><div style=\"display:flex;flex-direction:column;max-width:88%;align-self:flex-end\"><div style=\"background:#184623;border-radius:14px 14px 4px 14px;padding:8px 11px;font-size:11px;line-height:1.55;color:#D4F0D8\">Summarize those emails and draft replies</div><div style=\"font-size:8px;color:rgba(134,201,148,0.3);font-family:var(--font-jetbrains), monospace;margin-top:3px;padding:0 3px;text-align:right\">8:03 AM ✓✓</div></div><div style=\"display:flex;flex-direction:column;max-width:88%;align-self:flex-start\"><div style=\"background:#1E2E21;border:0.5px solid rgba(74,143,93,0.2);border-radius:14px 14px 14px 4px;padding:8px 11px;font-size:11px;line-height:1.55;color:#C8E8CC\">Done. 4 summaries ready, 3 draft replies written. Send or save as drafts?</div><div style=\"font-size:8px;color:rgba(134,201,148,0.3);font-family:var(--font-jetbrains), monospace;margin-top:3px;padding:0 3px\">8:03 AM</div></div><div style=\"display:flex;flex-direction:column;max-width:88%;align-self:flex-end\"><div style=\"background:#184623;border-radius:14px 14px 4px 14px;padding:8px 11px;font-size:11px;line-height:1.55;color:#D4F0D8\">Save as drafts</div><div style=\"font-size:8px;color:rgba(134,201,148,0.3);font-family:var(--font-jetbrains), monospace;margin-top:3px;padding:0 3px;text-align:right\">8:04 AM ✓✓</div></div><div style=\"display:flex;flex-direction:column;max-width:88%;align-self:flex-start\"><div style=\"background:#1E2E21;border:0.5px solid rgba(74,143,93,0.2);border-radius:14px 14px 14px 4px;padding:8px 11px;font-size:10px;line-height:1.7;color:var(--g-light);font-family:var(--font-jetbrains), monospace\">✓ 3 drafts saved to inbox<br/>✓ Overdue task rescheduled<br/>✓ Memory updated</div><div style=\"font-size:8px;color:rgba(134,201,148,0.3);font-family:var(--font-jetbrains), monospace;margin-top:3px;padding:0 3px\">8:04 AM</div></div></div><div style=\"background:#17211A;padding:8px 10px;display:flex;align-items:center;gap:7px;border-top:0.5px solid rgba(74,143,93,0.15)\"><div style=\"flex:1;background:#1E2620;border-radius:16px;height:26px;display:flex;align-items:center;padding:0 10px\"><span style=\"font-size:9px;color:rgba(134,201,148,0.25);font-family:var(--font-jetbrains), monospace\">Message operator...</span></div><div style=\"width:24px;height:24px;background:var(--g);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0\"><svg viewBox=\"0 0 10 10\" fill=\"none\" style=\"width:10px;height:10px\"><path d=\"M1 9L9 5L1 1V4.5L6.5 5L1 5.5V9Z\" fill=\"white\"></path></svg></div></div></div></div></div></section><div style=\"border-top:0.5px solid rgba(74,143,93,0.18);border-bottom:0.5px solid rgba(74,143,93,0.18);background:rgba(15,21,16,0.7)\"><div class=\"mx-auto flex items-center justify-center px-8 py-7\" style=\"max-width:1200px;margin:0 auto;gap:4rem\"><div class=\"flex flex-col items-center\"><div class=\"font-extrabold\" style=\"font-size:1.75rem;color:#F0F7F1;letter-spacing:-0.03em;line-height:1;margin-bottom:4px\">3K+</div><div class=\"text-xs uppercase\" style=\"color:rgba(134,201,148,0.45);letter-spacing:0.08em;font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\">Community Members</div></div><div style=\"width:0.5px;height:32px;background:rgba(74,143,93,0.2)\"></div><div class=\"flex flex-col items-center\"><div class=\"font-extrabold\" style=\"font-size:1.75rem;color:#F0F7F1;letter-spacing:-0.03em;line-height:1;margin-bottom:4px\">99.9%</div><div class=\"text-xs uppercase\" style=\"color:rgba(134,201,148,0.45);letter-spacing:0.08em;font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\">SLA-backed Uptime</div></div><div style=\"width:0.5px;height:32px;background:rgba(74,143,93,0.2)\"></div><div class=\"flex flex-col items-center\"><div class=\"font-extrabold\" style=\"font-size:1.75rem;color:#F0F7F1;letter-spacing:-0.03em;line-height:1;margin-bottom:4px\">&lt;5min</div><div class=\"text-xs uppercase\" style=\"color:rgba(134,201,148,0.45);letter-spacing:0.08em;font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\">Deploy Time</div></div></div></div><div class=\"mx-auto\" style=\"height:0.5px;background:rgba(74,143,93,0.18);max-width:1200px\"></div><section id=\"features\" class=\"w-full py-24\"><div class=\"mx-auto px-8\" style=\"max-width:1200px\"><div class=\"mb-3 text-xs font-medium uppercase\" style=\"color:var(--g);letter-spacing:0.1em;font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\">What&#x27;s included</div><h2 class=\"mb-4 font-extrabold leading-tight\" style=\"font-size:clamp(2rem, 4vw, 2.8rem);letter-spacing:-0.03em;line-height:1.1;color:#F0F7F1\">Built for people,<br/>not engineers.</h2><p class=\"mb-8 text-base\" style=\"color:rgba(134,201,148,0.65);max-width:640px;line-height:1.75;margin-bottom:2rem\">Everything you need to run a personal AI agent — from setup to daily use.</p><div class=\"grid overflow-hidden rounded-2xl\" style=\"grid-template-columns:repeat(3, 1fr);gap:1px;background:rgba(74,143,93,0.18);border:0.5px solid rgba(74,143,93,0.18);align-items:stretch\"><div class=\"flex flex-col p-8 transition-colors hover:bg-[#181E19]\" style=\"background:var(--surface)\"><div class=\"mb-5 flex h-10 w-10 items-center justify-center rounded-xl text-lg\" style=\"background:var(--g-dark);border:0.5px solid var(--g);flex-shrink:0\">⚡</div><h3 class=\"mb-2 text-base font-bold\" style=\"color:#E8F0E9;letter-spacing:-0.01em\">No terminal needed</h3><p class=\"text-sm leading-relaxed\" style=\"color:rgba(134,201,148,0.65);line-height:1.65;flex-grow:1\">Set up your agent through a simple step-by-step process. No SSH, no CLI, no DevOps experience required.</p></div><div class=\"flex flex-col p-8 transition-colors hover:bg-[#181E19]\" style=\"background:var(--surface)\"><div class=\"mb-5 flex h-10 w-10 items-center justify-center rounded-xl text-lg\" style=\"background:var(--g-dark);border:0.5px solid var(--g);flex-shrink:0\">🔒</div><h3 class=\"mb-2 text-base font-bold\" style=\"color:#E8F0E9;letter-spacing:-0.01em\">Dedicated server</h3><p class=\"text-sm leading-relaxed\" style=\"color:rgba(134,201,148,0.65);line-height:1.65;flex-grow:1\">Your agent runs on its own isolated instance. Your data stays yours — always. No shared runtimes.</p></div><div class=\"flex flex-col p-8 transition-colors hover:bg-[#181E19]\" style=\"background:var(--surface)\"><div class=\"mb-5 flex h-10 w-10 items-center justify-center rounded-xl text-lg\" style=\"background:var(--g-dark);border:0.5px solid var(--g);flex-shrink:0\">🎛</div><h3 class=\"mb-2 text-base font-bold\" style=\"color:#E8F0E9;letter-spacing:-0.01em\">Full control</h3><p class=\"text-sm leading-relaxed\" style=\"color:rgba(134,201,148,0.65);line-height:1.65;flex-grow:1\">Bring your own AI key or use ours. Choose your integrations — Telegram, Discord, Slack — and configure everything your way.</p></div><div class=\"flex flex-col p-8 transition-colors hover:bg-[#181E19]\" style=\"background:var(--surface)\"><div class=\"mb-5 flex h-10 w-10 items-center justify-center rounded-xl text-lg\" style=\"background:var(--g-dark);border:0.5px solid var(--g);flex-shrink:0\">🌍</div><h3 class=\"mb-2 text-base font-bold\" style=\"color:#E8F0E9;letter-spacing:-0.01em\">Global infrastructure</h3><p class=\"text-sm leading-relaxed\" style=\"color:rgba(134,201,148,0.65);line-height:1.65;flex-grow:1\">Powered by Hetzner data centers worldwide. Low latency, high availability, 99.9% uptime SLA.</p></div><div class=\"flex flex-col p-8 transition-colors hover:bg-[#181E19]\" style=\"background:var(--surface)\"><div class=\"mb-5 flex h-10 w-10 items-center justify-center rounded-xl text-lg\" style=\"background:var(--g-dark);border:0.5px solid var(--g);flex-shrink:0\">🤖</div><h3 class=\"mb-2 text-base font-bold\" style=\"color:#E8F0E9;letter-spacing:-0.01em\">Multi-model support</h3><p class=\"text-sm leading-relaxed\" style=\"color:rgba(134,201,148,0.65);line-height:1.65;flex-grow:1\">Choose from ChatGPT, Gemini, MiniMax, and more supported providers. Switch anytime — no lock-in.</p></div><div class=\"flex flex-col p-8 transition-colors hover:bg-[#181E19]\" style=\"background:var(--surface)\"><div class=\"mb-5 flex h-10 w-10 items-center justify-center rounded-xl text-lg\" style=\"background:var(--g-dark);border:0.5px solid var(--g);flex-shrink:0\">🐵</div><h3 class=\"mb-2 text-base font-bold\" style=\"color:#E8F0E9;letter-spacing:-0.01em\">Community-built</h3><p class=\"text-sm leading-relaxed\" style=\"color:rgba(134,201,148,0.65);line-height:1.65;flex-grow:1\">Built by MonkeDAO on OpenClaw. 3,000+ members strong and growing — shaping what personal AI looks like.</p></div></div></div></section><div class=\"mx-auto\" style=\"height:0.5px;background:rgba(74,143,93,0.18);max-width:1200px\"></div><section id=\"pricing\" class=\"w-full py-24\"><div class=\"mx-auto px-8\" style=\"max-width:1200px\"><div class=\"mb-3 text-xs font-medium uppercase\" style=\"color:var(--g);letter-spacing:0.1em;font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\">Pricing</div><h2 class=\"mb-4 font-extrabold leading-tight\" style=\"font-size:clamp(2rem, 4vw, 2.8rem);letter-spacing:-0.03em;line-height:1.1;color:#F0F7F1\">Simple pricing.<br/>No surprises.</h2><p class=\"mb-4 text-base\" style=\"color:rgba(134,201,148,0.65);line-height:1.75\">Server hosting from $9/mo. Bring your own AI key, or choose a fully managed plan.<!-- --> <!-- -->No hidden fees.</p><p class=\"mb-12 text-sm italic\" style=\"color:rgba(134,201,148,0.5);margin-bottom:3rem\">Don&#x27;t have an AI subscription? We offer fully managed plans —<!-- --> <a href=\"mailto:hello@monke.is\" class=\"underline hover:text-[var(--g-light)]\">contact us</a> <!-- -->to learn more.</p><div class=\"grid gap-6\" style=\"grid-template-columns:repeat(3, 1fr);max-width:1080px;align-items:stretch\"><div class=\"relative\"><div class=\"flex flex-col rounded-2xl p-8\" style=\"background:var(--surface);border:0.5px solid rgba(74,143,93,0.18);flex-grow:1\"><div class=\"mb-3 text-xs font-semibold uppercase\" style=\"color:rgba(134,201,148,0.55);letter-spacing:0.08em;font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace\">Community</div><div class=\"mb-1 flex items-baseline gap-0.5\"><span class=\"font-extrabold\" style=\"color:#F0F7F1;letter-spacing:-0.04em;line-height:1;font-size:3rem\">$9</span></div><div class=\"mb-8 text-xs\" style=\"color:rgba(134,201,148,0.4);font-family:var(--font-jetbrains), &#x27;JetBrains Mono&#x27;, monospace;margin-bottom:2rem\">/ month</div><ul class=\"mb-8 flex-1 space-y-3\"><li class=\"flex items-center gap-2.5 text-sm\" style=\"color:rgba(134,201,148,0.65);line-height:1.5\"><span class=\"flex h-4 w-4 shrink-0 items-center justify-center rounded\" style=\"backgro